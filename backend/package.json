{
  "name": "volegram-chat-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --outfile=dist/index.js --format=esm --external:pg-native --banner:js=\"import{createRequire}from'module';const require=createRequire(import.meta.url);\"",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "drizzle-orm": "^0.30.0",
    "express": "^4.18.2",
    "express-session": "^1.18.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.3",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/multer": "^1.4.11",
    "@types/pg": "^8.11.3",
    "@types/ws": "^8.5.10",
    "esbuild": "^0.20.2",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  }
}
